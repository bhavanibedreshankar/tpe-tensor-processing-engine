#!/usr/bin/env bash
# Thin exec wrapper so `run_sim -test <name>` works without sourcing
# env.sh or activating the venv first. See tools/run_sim.py for the
# actual implementation and docs/HANDBOOK.md for usage.
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PY="$REPO_ROOT/.venv/bin/python3"
if [ ! -x "$PY" ]; then
    echo "run_sim: $REPO_ROOT/.venv not found -- run 'make venv' first" >&2
    exit 1
fi
exec "$PY" "$REPO_ROOT/tools/run_sim.py" "$@"
